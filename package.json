{
  "name": "comet_back",
  "version": "1.0.0",
  "description": "back-end dealing with Comet Spaceways user account management",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon server.js",
    "start": "NODE_ENV=production nodemon server.js",
    "reset:db": "DB_RESET_MODE=total node db/reset-db.js",
    "reset:users": "DB_RESET_MODE=partial DB_RESET_COLLECTION=users node db/reset-db.js",
    "reset:destinations": "DB_RESET_MODE=partial DB_RESET_COLLECTION=destinations node db/reset-db.js",
    "reset:flights": "DB_RESET_MODE=partial DB_RESET_COLLECTION=flights node db/reset-db.js",
    "reset:races": "DB_RESET_MODE=partial DB_RESET_COLLECTION=races node db/reset-db.js"
  },
  "author": "David Castejon Ferrer",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongoose": "^9.6.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
